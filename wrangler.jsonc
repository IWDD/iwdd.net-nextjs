{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "iwdd-net-nextjs",
  "compatibility_date": "2026-03-19",
  "compatibility_flags": [
    "nodejs_compat"
  ],
  "observability": {
    "enabled": true
  },
  "routes": [
    {
      "pattern": "iwdd.net",
      "custom_domain": true
    },
    {
      "pattern": "www.iwdd.net",
      "custom_domain": true
    }
  ]
}
